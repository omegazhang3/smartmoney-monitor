# OKX Smart Money Monitor 配置
# 复制为 .env 并填入你的配置

# Telegram 通知（可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 监控间隔（分钟）
MONITOR_INTERVAL=5

# 聪明钱筛选条件
# 最小PnL（美元）
MIN_PNL=10000
# 最小胜率（0-100）
MIN_WIN_RATE=60
# 最大回撤（0-100）
MAX_DRAWDOWN=50
# 排序方式：pnl / pnlRatio / winRate
SORT_BY=pnl
# 时间周期：3 / 7 / 30 / 90（天）
PERIOD=7

# 监控的币种（逗号分隔，留空=自动发现top20热门币）
WATCH_INSTRUMENTS=BTC,ETH,SOL

# 信号阈值
# 多空比变化阈值（%），超过此值才通知
SIGNAL_CHANGE_THRESHOLD=10

# 日志
LOG_FILE=./logs/smartmoney.log
